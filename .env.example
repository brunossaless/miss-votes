# PostgreSQL (rede interna Docker — não exposto na internet)
POSTGRES_USER=missvotes
POSTGRES_PASSWORD=changeme
POSTGRES_DB=missvotes

# Porta pública desta app na VPS (cada app usa uma porta diferente)
# Ex.: miss-votes=8080, outra-app=8081, site principal=80
PUBLIC_HTTP_PORT=8080

# Porta interna do Next.js (dev local com docker-compose.dev.yml)
APP_PORT=3000

SEED_DATABASE=true

# Prisma — dev local com Postgres exposto (docker-compose.db.yml)
DATABASE_URL="postgresql://missvotes:changeme@localhost:5432/missvotes"
